# ==========================================================
# DeepSpeci Environment Variables
# ==========================================================
# Copy this file to .env and fill in your secrets.
# Values here override config.yaml entries.
# ==========================================================

# --- Default LLM Provider ---
# Supported: mock | copilot | openai | azure_openai | ollama
DEFAULT_LLM_PROVIDER=copilot

# --- GitHub Copilot ---
COPILOT_ACCESS_TOKEN=

# --- REST LLM (OpenAI / Azure OpenAI / Ollama) ---
REST_LLM_API_KEY=

LLM_MODEL_NAME=Kimi K2.5
LLM_ENDPOINT=https://api.moonshot.cn/v1/chat/completions

# --- Jira ---
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Confluence ---
CONFLUENCE_URL=
CONFLUENCE_API_TOKEN=
